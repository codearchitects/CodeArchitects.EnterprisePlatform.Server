<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net7.0;net9.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <WarningsAsErrors>Nullable</WarningsAsErrors>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <DaprClientVersion Condition="'$(TargetFramework)' == 'net7.0'">1.9.0</DaprClientVersion>
    <DaprClientVersion Condition="'$(TargetFramework)' == 'net9.0'">1.15.4</DaprClientVersion>
    <DaprClientVersion Condition="'$(TargetFramework)' == 'net10.0'">1.16.1</DaprClientVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dapr.Client" Version="$(DaprClientVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Common\CodeArchitects.Platform.Common.csproj" />
    <ProjectReference Include="..\Messaging\CodeArchitects.Platform.Messaging.csproj" />
  </ItemGroup>

</Project>
