{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Caep": {
    "Dapr": {
      "Messaging": {
        "DefaultBus": "messagebus",
        "Handlers": {
          "MicroserviceB.Infrastructure.Handlers.PingPongHandler, MicroserviceB": {
            "Methods": [
              {
                "MessageType": "MicroserviceB.Domain.Messaging.PingMessage, MicroserviceB",
                "ResultTypes": [
                  "MicroserviceB.Domain.Messaging.PongMessage, MicroserviceB",
                  "MicroserviceB.Domain.Messaging.PointMessage, MicroserviceB"
                ],
                "Bus": "messagebus",
                "Topic": "ping",
                "Output": [
                  {
                    "Name": "$MessageBus",
                    "Metadata": {
                      "Bus": "messagebus",
                      "Topic": "pong",
                      "AllowedTypes": [
                        "MicroserviceB.Domain.Messaging.PongMessage, MicroserviceB"
                      ]
                    }
                  },
                  {
                    "Name": "$MessageBus",
                    "Metadata": {
                      "Bus": "messagebus",
                      "Topic": "point",
                      "AllowedTypes": [
                        "MicroserviceB.Domain.Messaging.PointMessage, MicroserviceB"
                      ]
                    }
                  }
                ]
              },
              {
                "MessageType": "MicroserviceB.Domain.Messaging.PointMessage, MicroserviceB",
                "Bus": "messagebus",
                "Topic": "point"
              }
            ]
          }
        }
      },
      "State": {
        "DefaultStore": "statestore"
      }
    }
  }
}
