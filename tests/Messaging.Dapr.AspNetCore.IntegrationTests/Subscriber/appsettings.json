{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Caep": {
    "Dapr": {
      "Messaging": {
        "DefaultBus": "messagebus",
        "Handlers": {
          "Subscriber.NoResult.ByConfigurationNoResultMessageHandler": {
            "Methods": [
              {
                "Bus": "messagebus",
                "Topic": "by-configuration",
                "MessageName": "Subscriber.NoResult.NoResultMessage"
              }
            ]
          },
          "Subscriber.WithResult.ByConfigurationWithResultMessageHandler": {
            "Methods": [
              {
                "Bus": "messagebus",
                "Topic": "by-configuration",
                "MessageName": "Subscriber.WithResult.WithResultMessage",
                "ResultName": "Subscriber.WithResult.Result",
                "Output": [
                  {
                    "Name": "Subscriber.WithResult.ITestOutputMetadata",
                    "Metadata": {
                      "Data": "some string"
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }
}
