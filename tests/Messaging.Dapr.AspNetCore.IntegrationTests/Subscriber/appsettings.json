{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Caep": {
    "Dapr": {
      "Messaging": {
        "DefaultBus": "messagebus",
        "Handlers": {
          "Subscriber.NoResult.ByConfigurationNoResultMessageHandler, Subscriber": {
            "Methods": [
              {
                "Bus": "messagebus",
                "Topic": "by-configuration",
                "MessageType": "Subscriber.NoResult.NoResultMessage, Subscriber"
              }
            ]
          },
          "Subscriber.WithResult.ByConfigurationWithResultMessageHandler, Subscriber": {
            "Methods": [
              {
                "Bus": "messagebus",
                "Topic": "by-configuration",
                "MessageType": "Subscriber.WithResult.WithResultMessage, Subscriber",
                "ResultType": "Subscriber.WithResult.Result, Subscriber",
                "Output": [
                  {
                    "Name": "Subscriber.WithResult.ITestOutputMetadata, Subscriber",
                    "Metadata": {
                      "Data": "some string",
                      "Type": "System.Object, System.Private.CoreLib"
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }
}
